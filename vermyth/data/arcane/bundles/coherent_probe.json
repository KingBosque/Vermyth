{
  "id": "coherent_probe",
  "version": 1,
  "kind": "decide",
  "summary": "Default policy probe with MIND+LIGHT and low side-effect tolerance",
  "description": "Expands to decide with a formatted objective and fixed aspects. Prefer this over hand-writing full intent JSON when you want a repeatable coherence check and arcane_provenance on the result.",
  "recommended_for": [
    "Routine ALLOW/RESHAPE/DENY checks where you only vary the subject (topic)",
    "Agents that should send fewer fields than a full intent + aspects object"
  ],
  "stability": "stable",
  "param_keys": ["topic"],
  "recommendation": {
    "target_skills": ["decide"],
    "why_better": "The bundle fixes aspects and intent shape, formats the objective, and adds arcane_provenance—less drift than repeating the same JSON by hand.",
    "tiers": [
      {
        "match_kind": "exact",
        "strength": 0.95,
        "require_all": [
          {
            "op": "aspects_eq",
            "value": ["MIND", "LIGHT"],
            "rule_id": "aspects"
          },
          {
            "op": "intent_subset_eq",
            "value": {
              "scope": "semantic_bundle",
              "reversibility": "REVERSIBLE",
              "side_effect_tolerance": "LOW"
            },
            "rule_id": "intent_shape"
          },
          {
            "op": "objective_starts_with",
            "value": "Probe coherence on ",
            "rule_id": "objective_prefix"
          }
        ]
      },
      {
        "match_kind": "advisory",
        "strength": 0.62,
        "require_all": [
          {
            "op": "aspects_eq",
            "value": ["MIND", "LIGHT"],
            "rule_id": "aspects"
          },
          {
            "op": "intent_subset_eq",
            "value": {
              "scope": "semantic_bundle",
              "reversibility": "REVERSIBLE",
              "side_effect_tolerance": "LOW"
            },
            "rule_id": "intent_shape"
          },
          {
            "op": "objective_starts_with",
            "value": "Probe coherence on ",
            "negate": true,
            "rule_id": "not_default_prefix"
          },
          {
            "op": "objective_length_between",
            "min_len": 1,
            "max_len": 159,
            "rule_id": "bounded_objective"
          }
        ]
      }
    ]
  },
  "template": {
    "intent": {
      "objective": "Probe coherence on {topic}",
      "scope": "semantic_bundle",
      "reversibility": "REVERSIBLE",
      "side_effect_tolerance": "LOW"
    },
    "aspects": ["MIND", "LIGHT"]
  }
}
