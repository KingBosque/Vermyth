{
  "id": "strict_ward_probe",
  "version": 1,
  "kind": "decide",
  "library": "canonical",
  "summary": "Stricter policy gates (high allow_min_resonance + effect-risk floor)",
  "description": "Encodes ward-style thresholds (0.92 allow_min_resonance, 0.95 effect_risk_min_score) so callers do not hand-merge PolicyThresholds for the same intent shape.",
  "recommended_for": [
    "Higher-stakes decisions where you want tighter ALLOW gates by default",
    "Avoiding copy-paste errors when setting thresholds on decide"
  ],
  "stability": "stable",
  "param_keys": ["topic"],
  "recommendation": {
    "target_skills": ["decide"],
    "why_better": "The bundle locks ward thresholds next to the intent so policy gates cannot silently drift from copy-paste edits.",
    "tiers": [
      {
        "match_kind": "exact",
        "strength": 0.94,
        "require_all": [
          {
            "op": "aspects_eq",
            "value": ["MIND"],
            "rule_id": "aspects"
          },
          {
            "op": "intent_subset_eq",
            "value": {
              "scope": "semantic_bundle",
              "reversibility": "REVERSIBLE",
              "side_effect_tolerance": "LOW"
            },
            "rule_id": "intent_shape"
          },
          {
            "op": "thresholds_eq",
            "value": {
              "allow_min_resonance": 0.92,
              "effect_risk_min_score": 0.95
            },
            "rule_id": "ward_thresholds"
          },
          {
            "op": "objective_starts_with",
            "value": "Warded coherence probe on ",
            "rule_id": "objective_prefix"
          }
        ]
      }
    ]
  },
  "template": {
    "intent": {
      "objective": "Warded coherence probe on {topic}",
      "scope": "semantic_bundle",
      "reversibility": "REVERSIBLE",
      "side_effect_tolerance": "LOW"
    },
    "aspects": ["MIND"],
    "thresholds": {
      "allow_min_resonance": 0.92,
      "effect_risk_min_score": 0.95
    }
  }
}
