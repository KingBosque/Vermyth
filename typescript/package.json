{
  "name": "vermyth",
  "version": "0.1.0",
  "description": "Semantic IR and decision runtime (TypeScript port)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vermyth-ts": "./dist/cli/main.js",
    "vermyth-mcp-ts": "./dist/mcp/entry.js",
    "vermyth-http-ts": "./dist/adapters/http-entry.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "sync-assets": "node scripts/sync-assets.mjs",
    "build": "npm run sync-assets && tsc -p tsconfig.build.json",
    "test": "npm run sync-assets && vitest run",
    "lint": "eslint src --max-warnings 0",
    "prepare": "npm run sync-assets"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "commander": "^12.1.0",
    "ulidx": "^2.4.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vitest": "^3.0.4"
  }
}
